# ─── Server ───────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-32-chars

# ─── Stripe ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get this from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these in https://dashboard.stripe.com/products
# Add 3 products: Starter $49/mo, Pro $99/mo, Executive $199/mo
# Then copy the Price ID (starts with price_...) for each
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_EXECUTIVE_PRICE_ID=price_...

# ─── OpenRouter / AI ───────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# Agentic Placement System — Environment Variables
# Copy this to your server/.env and fill in the values

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/westleyresource

# ─── Gemini (required for agents + embeddings) ───────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Microsoft Graph (for email outreach) ────────────────────
MS_TENANT_ID=your_azure_tenant_id
MS_CLIENT_ID=your_azure_client_id
MS_CLIENT_SECRET=your_azure_client_secret
MS_SENDER=support@westleyresource.com

# ─── Twilio (optional SMS fallback) ──────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Agent Behaviour ─────────────────────────────────────────
VMS_POLL_INTERVAL_SECONDS=300
MATCH_TOP_K=5
OUTREACH_WAIT_HOURS=48
MAX_TASK_ATTEMPTS=3
ORCHESTRATOR_PORT=8200

# ─── Job Scrapers (optional — adds live job sourcing) ────────
# Sign up free at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Sign up free at https://rapidapi.com → subscribe to JSearch
RAPIDAPI_KEY=

# USAJobs.gov — free key from https://developer.usajobs.gov/ (email signup)
USAJOBS_API_KEY=
USAJOBS_EMAIL=recruiter@westleyresource.com
